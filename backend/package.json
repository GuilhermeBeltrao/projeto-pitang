    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.13",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
